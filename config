# promptr runtime configuration
# Each key falls back to the compile-time default if missing.

[preferences]
# Window size in pixels
width=900
height=700

# Layer-shell overlay on wlroots compositors (0 or 1)
layer_shell=0

# Desktop notification on copy (0 or 1)
notify_on_copy=1

# Hex color for marked-line gutter indicator
mark_bg_color=#33cc7f

# Keyboard shortcuts (GTK accelerator string format, e.g. "<Control>k")
kb_focus_prompt=<Control>k
kb_copy_marked=<Control><Shift>c
kb_close=<Control>q
kb_quit=<Control><Shift>q
kb_log=<Control><Shift>d
kb_shortcuts=<Control>F1
kb_submit=<Control>Return
kb_cancel=

# Path to the opencode binary
opencode_path=opencode

# Agent dropdown options (comma-separated, first=default)
agent_options=linux_cmd,None

# Model dropdown options (comma-separated, first=default)
model_options=opencode-go/deepseek-v4-flash,opencode-go/deepseek-v4-pro,opencode/big-pickle,opencode/deepseek-v4-flash-free,None

# Default marked lines on output (0=all, -1=none, or comma-separated 1-based)
marked_lines=1

# Window decorations when layer-shell is disabled (0 or 1)
decorated=1

# Command section expanded by default (0 or 1)
command_expanded=0

# Font size in pt for prompt text (0 = system default)
prompt_font_size=0

# Font size in pt for output text (0 = system default)
output_font_size=0

# GSK renderer backend (set before gtk_init, not switchable at runtime):
#   cairo  - software (CPU), no GPU allocations, ~half baseline memory
#   ngl    - OpenGL (GPU), GTK 4.14+ default, highest memory usage
#   gl     - OpenGL (GPU), deprecated in 4.14, aliases to ngl
#   vulkan - Vulkan (GPU), similar memory to GL; requires Vulkan driver
gsk_renderer=cairo
